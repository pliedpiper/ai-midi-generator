# Supabase project URL and anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Legacy fallback (optional): NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side secret used to encrypt user OpenRouter API keys before DB storage
OPENROUTER_KEY_ENCRYPTION_SECRET=replace-with-a-long-random-secret

# Redis for distributed rate limiting (set ONE pair)
# Preferred on Vercel KV:
KV_REST_API_URL=https://your-kv-instance.upstash.io
KV_REST_API_TOKEN=your_kv_rest_token
# Or direct Upstash Redis fallback:
# UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# Optional CSP rollout controls:
# CSP_REPORT_ONLY=true
# CSP_REPORT_URI=https://your-csp-report-endpoint.example/report
